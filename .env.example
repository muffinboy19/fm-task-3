

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY2=
GEMINI_API_KEY3=
GEMINI_MODEL=gemini-2.5-flash
LLM_PROVIDER=cursor
CURSOR_API_KEY=your_cursor_api_key_here
# Use "default" for local SDK runs; composer-2.5 may fail with status=error on local runtime
CURSOR_MODEL=default
OUTPUT_DIR=./output
LOG_DIR=./logs
DRY_RUN=false
DASHBOARD_UI=true
DASHBOARD_PORT=8765
VALIDATION_FULL=false
GO_BIN=/opt/homebrew/bin/go
