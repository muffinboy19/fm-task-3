# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Gemini (required) ──────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY2=
GEMINI_API_KEY3=
GEMINI_MODEL=gemini-2.5-flash

# ── GitHub (optional) ───────────────────────────────────────────
# GITHUB_TOKEN — optional; needed for private repos when fetching the issue
# GITHUB_ISSUE_URL — only used with: python main.py --issue <url>
# GITHUB_ISSUE_URL=https://github.com/gin-gonic/gin/issues/1234

# Optional: where clones live (default: ./test_repo)
# TEST_REPO_DIR=./test_repo


# ── LLM provider: cursor (recommended) or gemini ───────────────
LLM_PROVIDER=cursor
CURSOR_API_KEY=your_cursor_api_key_here
CURSOR_MODEL=composer-2.5

# ── Run options ────────────────────────────────────────────────
OUTPUT_DIR=./output
LOG_DIR=./logs
DRY_RUN=false

# Live HTML dashboard (pipeline steps, logs, diff viewer)
DASHBOARD_UI=true
DASHBOARD_PORT=8765

# Validation: package-scoped go test by default; set true for go test ./...
VALIDATION_FULL=false

# Path to go binary if not on PATH (e.g. /opt/homebrew/bin/go on Apple Silicon)
GO_BIN=/opt/homebrew/bin/go
