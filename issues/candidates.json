{
  "guardrails": {
    "prefer": [
      "clear reproduction in issue body",
      "localized fix (1-3 files)",
      "bug label or explicit bug report",
      "has failing test example or expected/actual"
    ],
    "avoid": [
      "security",
      "CVE",
      "architectural",
      "rewrite",
      "breaking change",
      "design proposal",
      "dependencies upgrade",
      "linter false positive",
      "cgo",
      "unclear maintainer decision",
      "help wanted investigation only"
    ],
    "max_comments_for_ambiguity": 30
  },
